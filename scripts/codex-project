#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SUPABASE_MCP_URL="https://mcp.supabase.com/mcp?project_ref=lljkdjijozfnjqbkntce&features=docs%2Caccount%2Cdatabase%2Cdebugging%2Cdevelopment%2Cfunctions%2Cbranching%2Cstorage"

if [[ -f "$ROOT_DIR/.env.local" ]]; then
  set -a
  # shellcheck disable=SC1091
  source "$ROOT_DIR/.env.local"
  set +a
fi

cd "$ROOT_DIR"
exec codex \
  -c 'mcp_servers.supabase.url="'"$SUPABASE_MCP_URL"'"' \
  -c 'mcp_servers.supabase.bearer_token_env_var="SUPABASE_ACCESS_TOKEN"' \
  "$@"
